# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
APP_ENV=development

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=host=localhost user=postgres password=postgres dbname=tachigo port=5432 sslmode=disable

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace-with-a-strong-random-secret-32-chars
JWT_REFRESH_SECRET=replace-with-another-strong-random-secret-32-chars
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30

# ── Twitch OAuth ──────────────────────────────────────────────────────────────
# Register at https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URL=http://localhost:8080/api/v1/auth/twitch/callback

# ── Twitch Extension ───────────────────────────────────────────────────────────
# Found in the Extension dashboard → "Extension Secret" (base64-encoded)
TWITCH_EXTENSION_SECRET=

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Register at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# ── Tachi Contract ────────────────────────────────────────────────────────────
# Contract address used by upcoming backend contract integration.
# Verification note: as of issue #175, backend/internal/config/config.go does not load TACHI_CONTRACT_ADDRESS yet.
TACHI_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Sepolia signer private key for transaction signing in non-production environments only.
# Never commit a real key. In production, store signing credentials in a secrets manager or use a hardware wallet.
SEPOLIA_SIGNER_KEY=replace-with-sepolia-signer-private-key

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174
