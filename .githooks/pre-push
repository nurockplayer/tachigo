#!/usr/bin/env bash

set -euo pipefail

remote="${1:-origin}"
script_dir="$(cd "$(dirname "$0")/.." && pwd)"
checker="$script_dir/scripts/pr-scope-check.sh"

if [ ! -x "$checker" ]; then
  chmod +x "$checker"
fi

while read -r local_ref local_sha remote_ref remote_sha; do
  [ -n "$local_ref" ] || continue
  "$checker" --ref "$local_ref" "$local_sha" "$remote" "$remote_ref"
done
