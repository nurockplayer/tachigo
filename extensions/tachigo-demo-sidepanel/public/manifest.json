{
  "manifest_version": 3,
  "name": "Tachigo Demo Side Panel",
  "description": "Demo side panel extension for the Tachigo login, loading, and HUD flow.",
  "version": "0.0.1",
  "permissions": ["sidePanel", "storage"],
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_title": "Open Tachigo demo",
    "default_icon": {
      "16": "icon.png",
      "32": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
